{
  "expo": {
    "name": "MineMind",
    "slug": "minemind",
    "scheme": "minemind",
    "version": "0.1.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "light",
    "splash": {
      "image": "./assets/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#132017"
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.alina.minemind",
      "infoPlist": {
        "NSLocalNetworkUsageDescription": "MineMind uses your local network to host classroom matches on nearby devices."
      }
    },
    "android": {
      "package": "com.alina.minemind",
      "permissions": [
        "INTERNET",
        "ACCESS_WIFI_STATE",
        "CHANGE_WIFI_MULTICAST_STATE"
      ],
      "adaptiveIcon": {
        "backgroundColor": "#132017",
        "foregroundImage": "./assets/android-icon-foreground.png",
        "backgroundImage": "./assets/android-icon-background.png",
        "monochromeImage": "./assets/android-icon-monochrome.png"
      },
      "predictiveBackGestureEnabled": false
    },
    "web": {
      "favicon": "./assets/favicon.png"
    },
    "plugins": [
      "expo-router",
      "expo-localization",
      "expo-secure-store"
    ],
    "experiments": {
      "typedRoutes": true
    },
    "extra": {
      "router": {},
      "eas": {
        "projectId": "4e8dbd53-0ca8-4db9-af68-aef8abe6e3b0"
      }
    },
    "owner": "slonce70"
  }
}
